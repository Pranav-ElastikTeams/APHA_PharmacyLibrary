# =============================================================================
# BROWSER MODE
# =============================================================================
# "cdp"    → connects to Edge opened by open-edge.bat (avoids bot detection).
#            Run open-edge.bat <BROWSERS> and log in manually in each window.
# "launch" → launches fresh Chromium browser(s) automatically via AUTH below.
#
BROWSER_MODE=cdp

# Number of browser instances to open in parallel.
# CDP mode:    run  open-edge.bat <BROWSERS>  to open matching Edge windows on consecutive ports.
# Launch mode: script launches them automatically using AUTH credentials below.
BROWSERS=1

# CDP mode: base debug port. Script connects to this port, port+1, port+2, …
# open-edge.bat opens windows on the same consecutive ports.
CDP_BASE_PORT=9222

# Total number of parallel worker tabs spread across all browsers.
CONCURRENCY=20

# =============================================================================
# SCRAPE-QUESTIONS SCRIPT  (npm run scrape-questions → src/scrape-questions.ts)
# Reads DOIs from the production dim_item CSV and writes each page's question
# text into a `question_text` column NEXT TO the DOI in that same CSV (DOIs are
# only read — never added/removed/reordered). Re-runs fill/update questions.
# Reuses BROWSER_MODE / BROWSERS / CONCURRENCY / CDP_BASE_PORT / auth above.
# =============================================================================
# Leave BLANK to write the question_text column back into the production CSV
# in place. Set a path to write a separate copy instead (e.g. for a dry run).
SCRAPE_OUTPUT=

# --- Dynamic test setup -------------------------------------------------------
# SCRAPE_DOIS: comma-separated DOIs to scrape — full "10.21019/qna-636046" or
#   bare "qna-636046". When set, the production CSV is IGNORED and only these
#   are visited. Perfect for a quick smoke test. Leave blank to crawl them all.
SCRAPE_DOIS=

# SCRAPE_LIMIT: cap how many DOIs are processed this run (0 = no limit / all).
SCRAPE_LIMIT=0

# SCRAPE_FRESH: true = ignore output/scrape-questions-checkpoint.json and restart.
SCRAPE_FRESH=false

# Per-page tuning (ms). Lower content timeout = faster over dead pages.
SCRAPE_CONTENT_TIMEOUT=12000
SCRAPE_DELAY_MS=500

# Progress line cadence. Counts only THIS run's work — the still-empty
# question_text rows being scraped (filled rows are skipped, not counted).
#   1 = update on every DOI (default)   N = update every N DOIs   0 = silent
SCRAPE_PROGRESS_EVERY=1

# =============================================================================
# AUTH METHOD (only used when BROWSER_MODE=launch)
# =============================================================================
# "cookie" → inject CF and session cookies directly (bypasses Cloudflare)
# "login"  → fill the login form with username/password
#
AUTH_METHOD=cookie

# --- Form login settings (AUTH_METHOD=login) ---
AUTH_LOGIN_URL=https://pharmacylibrary.com/
AUTH_USERNAME=your-email@example.com
AUTH_PASSWORD=your-password-here

# --- Cookie injection settings (AUTH_METHOD=cookie) ---
# Get cf_clearance from browser DevTools → Application → Cookies
CF_CLEARANCE=your-cf_clearance-cookie-value-here
SESSION_COOKIE_NAME=JSESSIONID
SESSION_COOKIE_VALUE=your-jsessionid-cookie-value-here

# =============================================================================
# BROWSER DISPLAY
# =============================================================================
# HEADLESS=false  → opens a visible browser window (recommended for debugging)
# DEBUG_PAUSE=true → opens Playwright Inspector before the sweep starts
#
HEADLESS=false
DEBUG_PAUSE=false

# =============================================================================
# DEPOSIT SCRIPT  (npm run deposit  →  src/deposit.ts)
# Atypon WAT console → Impelsys deposit. Independent of the QA / find-dois scripts.
# Reuses the same Edge profile: run `open-edge.bat 1`, log in, then `npm run deposit`.
# =============================================================================

# Excel record (source of truth). Rows whose "Status from Atypon" is blank are pending;
# the script writes "started" + today's date back, so re-running resumes automatically.
DEPOSIT_RECORD_XLSX=Data/DOIs record/Migration_record.xlsx
DEPOSIT_SHEET=DOs

# Which Category column to deposit: NAPLEX | other | all
DEPOSIT_CATEGORY=NAPLEX

# App publication-type dropdown: "digital" (Digital Object Publication, default) or "books"
DEPOSIT_PUBLICATION_TYPE=digital

# App environment dropdown (the "Area" combo on the Backstage screen)
DEPOSIT_ENV_OPTION=Live

# Deposit exactly ONE DOI and stop (leave blank for the Excel-driven batch loop)
DEPOSIT_SINGLE_DOI=

# Optional cap on number of deposits this run (0 = no limit)
DEPOSIT_LIMIT=0

# Delay between two deposits, in milliseconds
DEPOSIT_DELAY_MS=5000

# Trial run: do everything EXCEPT the final Deposit/Yes confirmation (verifies selectors safely)
DEPOSIT_DRY_RUN=false

# Value written to the Status column when a deposit starts
DEPOSIT_STATUS_VALUE=started

# If true, also write "error: ..." to the Status column on failure (so it is skipped next run)
DEPOSIT_MARK_ERRORS=false

# (UI control names/labels are hard-coded in src/deposit.ts, not configured here.
#  DEBUG_PAUSE in the BROWSER DISPLAY section above opens the Playwright Inspector
#  right after /wat loads — handy for re-picking locators if the UI ever changes.)

# Timeouts (ms)
DEPOSIT_NAV_TIMEOUT=60000
DEPOSIT_SEL_TIMEOUT=30000
DEPOSIT_GRID_TIMEOUT=20000
DEPOSIT_ENABLE_TIMEOUT=30000
DEPOSIT_CONFIRM_TIMEOUT=6000
