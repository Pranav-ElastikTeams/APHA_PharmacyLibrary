# =============================================================================
# BROWSER MODE
# =============================================================================
# "cdp"    → connects to Edge opened by open-edge.bat (avoids bot detection).
#            Run open-edge.bat <BROWSERS> and log in manually in each window.
# "launch" → launches fresh Chromium browser(s) automatically via AUTH below.
#
BROWSER_MODE=cdp

# Number of browser instances to open in parallel.
# CDP mode:    run  open-edge.bat <BROWSERS>  to open matching Edge windows on consecutive ports.
# Launch mode: script launches them automatically using AUTH credentials below.
BROWSERS=1

# CDP mode: base debug port. Script connects to this port, port+1, port+2, …
# open-edge.bat opens windows on the same consecutive ports.
CDP_BASE_PORT=9222

# Total number of parallel worker tabs spread across all browsers.
CONCURRENCY=20

# =============================================================================
# AUTH METHOD (only used when BROWSER_MODE=launch)
# =============================================================================
# "cookie" → inject CF and session cookies directly (bypasses Cloudflare)
# "login"  → fill the login form with username/password
#
AUTH_METHOD=cookie

# --- Form login settings (AUTH_METHOD=login) ---
AUTH_LOGIN_URL=https://pharmacylibrary.com/
AUTH_USERNAME=your-email@example.com
AUTH_PASSWORD=your-password-here

# --- Cookie injection settings (AUTH_METHOD=cookie) ---
# Get cf_clearance from browser DevTools → Application → Cookies
CF_CLEARANCE=your-cf_clearance-cookie-value-here
SESSION_COOKIE_NAME=JSESSIONID
SESSION_COOKIE_VALUE=your-jsessionid-cookie-value-here

# =============================================================================
# BROWSER DISPLAY
# =============================================================================
# HEADLESS=false  → opens a visible browser window (recommended for debugging)
# DEBUG_PAUSE=true → opens Playwright Inspector before the sweep starts
#
HEADLESS=false
DEBUG_PAUSE=false
